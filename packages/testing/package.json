{
  "name": "@ll-score/testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed": "tsx --tsconfig tsconfig.seed.json src/seed-sample-cli.ts"
  },
  "dependencies": {
    "@ll-score/contracts": "workspace:*",
    "@ll-score/storage-core": "workspace:*",
    "@ll-score/storage-jsonl": "workspace:*"
  },
  "dependenciesMeta": {
    "@ll-score/contracts": {
      "injected": true
    },
    "@ll-score/storage-core": {
      "injected": true
    },
    "@ll-score/storage-jsonl": {
      "injected": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
